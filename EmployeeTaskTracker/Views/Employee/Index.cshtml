@model List<EmployeeTaskTracker.Models.Employee>

@{
    ViewData["Title"] = "Employee List";
}

<div class="container-fluid mt-4">

    <div class="card shadow border-0">

        <!-- Header -->
        <div class="card-header bg-primary text-white">

            <div class="d-flex justify-content-between align-items-center flex-wrap">

                <h2 class="mb-0">
                    Employee List
         
                </h2>

                <a asp-action="Create" class="btn btn-light fw-bold">
                    + Add Employee
                </a>

            </div>

        </div>

        <div class="card-body">

            <!-- Search -->
            <form method="get" class="mb-4">

                <div class="input-group">

                    <input type="text"
                           name="search"
                           value="@ViewBag.Search"
                           class="form-control"
                           placeholder="Search by name, email, phone..." />

                    <button type="submit" class="btn btn-primary">
                        🔍 Search
                    </button>

                </div>

            </form>

            <!-- Table -->
            <div class="table-responsive">

                <table class="table table-hover table-bordered align-middle">

                    <thead class="table-dark">

                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Age</th>
                            <th>Gender</th>
                            <th>Hobbies</th>
                            <th>DOB</th>
                            <th>Color</th>
                            <th style="min-width:180px;">Skill</th>
                            <th>File</th>
                            <th style="min-width:140px;">Action</th>
                        </tr>

                    </thead>

                    <tbody>

                        @if (Model != null && Model.Any())
                        {
                            @foreach (var e in Model)
                            {
                                <tr>

                                    <td>
                                        <span class="fw-bold">
                                            @e.Id
                                        </span>
                                    </td>

                                    <td>
                                        <span class="fw-semibold">
                                            @e.FirstName @e.LastName
                                        </span>
                                    </td>

                                    <td>@e.Email</td>

                                    <td>@e.PhoneNumber</td>

                                    <td>@e.Age</td>

                                    <td>
                                        @if (e.Gender == "Male")
                                        {
                                            <span class="badge bg-primary">
                                                Male
                                            </span>
                                        }
                                        else if (e.Gender == "Female")
                                        {
                                            <span class="badge bg-danger">
                                                Female
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                @e.Gender
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        @(e.Hobbies != null && e.Hobbies.Any()
                                            ? string.Join(", ", e.Hobbies)
                                            : "N/A")
                                    </td>

                                    <td>
                                        @e.DOB.ToString("dd MMM yyyy")
                                    </td>

                                    <td class="text-center">

                                        <div class="rounded-circle border mx-auto"
                                             title="@e.FavoriteColor"
                                             style="
                                            width:35px;
                                            height:35px;
                                            background-color:@e.FavoriteColor;">
                                        </div>

                                    </td>

                                    <td>

                                        <div class="progress" style="height:22px;">

                                            <div class="progress-bar"
                                                 role="progressbar"
                                                 style="width:@(e.SkillRange)%">

                                                @e.SkillRange%

                                            </div>

                                        </div>

                                    </td>

                                    <td>

                                        @if (!string.IsNullOrEmpty(e.FileName))
                                        {
                                            <a href="~/Uploads/@e.FileName"
                                                   target="_blank"
                                                   class="btn btn-info btn-sm text-white">

                                                View

                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">
                                                N/A
                                            </span>
                                        }

                                    </td>

                                    <td>

                                        <div class="btn-group">

                                            <a asp-action="Edit"
                                                   asp-route-id="@e.Id"
                                                   class="btn btn-warning btn-sm">

                                                Edit

                                            </a>

                                            <a asp-action="Delete"
                                                   asp-route-id="@e.Id"
                                                   class="btn btn-danger btn-sm"
                                                   onclick="return confirm('Are you sure you want to delete this employee?')">

                                                Delete

                                            </a>

                                        </div>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="12"
                                    class="text-center text-danger fw-bold py-4">

                                    No Employee Found

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

            <!-- Pagination -->
            @if (ViewBag.TotalPages > 1)
            {
                <nav class="mt-4">

                    <ul class="pagination justify-content-center">

                        @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">

                                <a class="page-link"
                                       asp-action="Index"
                                       asp-route-search="@ViewBag.Search"
                                       asp-route-page="@i">

                                    @i

                                </a>

                            </li>
                        }

                    </ul>

                </nav>
            }

        </div>

    </div>

</div>