@model EmployeeTask

<form asp-action="Edit">

    <input type="hidden"
           asp-for="Id" />

    <div class="mb-3">
        <label>Title</label>

        <input asp-for="Title"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Description</label>

        <textarea asp-for="Description"
                      class="form-control">
        </textarea>
        </div>

        <div class="mb-3">
            <label>Status</label>

            <select asp-for="Status"
                    class="form-control">

                <option>Pending</option>
                <option>In Progress</option>
                <option>Completed</option>

            </select>
        </div>

        <div class="mb-3">
            <label>Deadline</label>

            <input asp-for="Deadline"
                   type="date"
                   class="form-control" />
        </div>

        <button class="btn btn-primary">
            Update
        </button>

    </form>